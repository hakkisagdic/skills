{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "skill|grep|view|glob|edit|create|shell|powershell|read|write|bash|task|str_replace|file_search|run_in_terminal|run_script|run_command|task_complete",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PLUGIN_ROOT}/hooks/gate-skill.ps1"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File ${CLAUDE_PLUGIN_ROOT}/hooks/remind-skill.ps1"
          }
        ]
      }
    ]
  }
}
